{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Debet Manager",
  "version": "1.0.21",
  "identifier": "com.debetfinal.debtbook",
  "build": {
    "frontendDist": "../app"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Debet Manager",
        "width": 1100,
        "height": 760,
        "minWidth": 860,
        "minHeight": 620,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE1Q0FDNkQwNEM0NTQ1REQKUldUZFJVVk0wTWJLRlUrOCtjUXBxdStrcHdJL0dPbnZoWWp0UldxWGY3RDZVbm5tR3lJRnpJZTMK",
      "endpoints": [
        "https://github.com/ali208408/DebetManager/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
